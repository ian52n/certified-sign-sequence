############################################################
# CertifiedSignSequence.jl — CHUNKED FAST RIGOROUS (v6.2)
#
# Fixes vs v6.1:
# • Avoids Union constructor error by typing the local as
#   `last_below_box::Union{Nothing,Hyperrectangle} = nothing`.
#
# What this version does:
# • Integrates in 1.0 s *chunks* and announces each chunk number.
# • After each chunk: overapproximate to boxes and scan immediately.
# • Certify crossings with local bracketing (fixed TARGET_TIME_WIDTH).
# • Stop as soon as we hit a straddling slab that we cannot certify.
#
# Rigor:
# • Existence via endpoint sign change + local re-integration.
# • Direction: inf(dz/dt) > 0 on hull of {start, mid, end} boxes.
# • Uniform y-sign on the accepted time bracket for labeling (L/R/?).
############################################################

using ReachabilityAnalysis
using LazySets
using IntervalArithmetic
using Dates

const IA = IntervalArithmetic

# -------------------------------
# User knobs
# -------------------------------
const SECTION           = 27.0
const GLOBAL_T_MAX      = 25.0    # total horizon
const CHUNK_LEN         = 1.0     # integrate 1.0 s at a time
const TARGET_TIME_WIDTH = 0.05    # try 0.1 for faster/looser brackets

# Global flowpipe settings (coarser for speed)
const GLOBAL_ALG = TMJets21a(
    abstol=1e-8,    # loose tolerance
    orderT=4,       # low time order
    orderQ=1,       # low spatial order
    maxsteps=25000  # per-chunk cap
)

# Local bracketing settings (still rigorous, but fast-ish)
const LOCAL_ALG = TMJets21a(
    abstol=1e-11,   # a bit stricter than global
    orderT=6,
    orderQ=2,
    maxsteps=120000
)

# -------------------------------
# Lorenz vector field
# -------------------------------
@taylorize function lorenz!(dx, x, p, t)
    σ, ρ, β = 10.0, 28.0, 8/3
    dx[1] = σ * (x[2] - x[1])
    dx[2] = x[1] * (ρ - x[3]) - x[2]
    dx[3] = x[1] * x[2] - β * x[3]
end

# -------------------------------
# Helpers: boxes, bounds & times
# -------------------------------
box_of(S) = S isa Hyperrectangle ? S : overapproximate(S, Hyperrectangle)

function bounds_from_reachset(rs)
    X = set(rs) |> box_of
    l = Float64.(collect(LazySets.low(X)))
    h = Float64.(collect(LazySets.high(X)))
    return [(l[1], h[1]), (l[2], h[2]), (l[3], h[3])]
end

function xyz_intervals_from_box(B::Hyperrectangle)
    l = LazySets.low(B); h = LazySets.high(B)
    xI = IA.Interval(Float64(l[1]), Float64(h[1]))
    yI = IA.Interval(Float64(l[2]), Float64(h[2]))
    zI = IA.Interval(Float64(l[3]), Float64(h[3]))
    return xI, yI, zI
end

dz_interval(xI, yI, zI) = xI*yI - (8/3)*zI
hull3(a::IA.Interval, b::IA.Interval, c::IA.Interval) = IA.hull(IA.hull(a,b), c)

# Normalize any tspan-like object to (tlo, thi) as Float64
function tspan_tuple(obj)
    ts = tspan(obj)
    if ts isa Tuple
        return (float(ts[1]), float(ts[2]))
    elseif ts isa IA.Interval
        return (float(IA.inf(ts)), float(IA.sup(ts)))
    else
        try
            return (float(first(ts)), float(last(ts)))
        catch
            error("Unsupported tspan type: $(typeof(ts))")
        end
    end
end

# -------------------------------
# Local validated time bracketing (ABS times)
# Returns:
#   (success, t_lo_abs, t_hi_abs, yI_lo, yI_hi, dz_min, dz_max)
# On success:
#   sup z(t_lo_abs) < SECTION, inf z(t_hi_abs) > SECTION,
#   inf(dz/dt) > 0 on hull{start, mid, end}, and width ≤ TARGET_TIME_WIDTH.
# -------------------------------
function certify_upward_crossing!(
    lorenz!; B_below::Hyperrectangle, section::Float64,
    t_start_abs::Float64,
    T_guess::Float64 = 0.05,
    T_max_local::Float64 = 0.30,
    target_time_width::Float64 = TARGET_TIME_WIDTH,
    max_expand::Int = 8,
    max_bisect::Int = 22,
    alg_refined = LOCAL_ALG
)::Tuple{Bool,Float64,Float64,IA.Interval{Float64},IA.Interval{Float64},Float64,Float64}

    _, _, zI0 = xyz_intervals_from_box(B_below)
    if IA.sup(zI0) >= section
        return (false, 0.0, 0.0, IA.Interval(0,0), IA.Interval(0,0), 0.0, 0.0)
    end

    # 1) Expand forward until strictly above
    T = T_guess
    T_total = 0.0
    B_lo = B_below
    B_hi = B_below
    found = false

    for _ in 1:max_expand
        prob_loc = @ivp(x' = lorenz!(x), dim: 3, x(0) ∈ B_lo)
        sol_loc_tm = solve(prob_loc, T=T, alg=alg_refined)
        sol_loc = overapproximate(sol_loc_tm, Hyperrectangle)
        B_end = set(sol_loc[end]) |> box_of

        _, _, zI_end = xyz_intervals_from_box(B_end)
        if IA.inf(zI_end) > section
            B_hi = B_end
            found = true
            break
        else
            B_lo = B_end
            T_total += T
            if T_total >= T_max_local
                break
            end
            T = min(T*1.7, T_max_local - T_total)
            if T <= 0
                break
            end
        end
    end
    if !found
        return (false, 0.0, 0.0, IA.Interval(0,0), IA.Interval(0,0), 0.0, 0.0)
    end

    # 2) Bisection with direction check on hull{lo,mid,hi}
    τ_lo = T_total
    τ_hi = T_total + T
    last_dz_min = -Inf
    last_dz_max =  Inf

    mid_cache = Dict{Float64,Hyperrectangle}()

    for _ in 1:max_bisect
        τ_mid = (τ_lo + τ_hi) / 2

        B_mid = get!(mid_cache, τ_mid) do
            prob_mid = @ivp(x' = lorenz!(x), dim: 3, x(0) ∈ B_below)
            sol_mid_tm = solve(prob_mid, T=τ_mid, alg=alg_refined)
            sol_mid = overapproximate(sol_mid_tm, Hyperrectangle)
            set(sol_mid[end]) |> box_of
        end

        xI_lo, yI_lo, zI_lo = xyz_intervals_from_box(B_lo)
        xI_mid, yI_mid, zI_mid = xyz_intervals_from_box(B_mid)
        xI_hi, yI_hi, zI_hi = xyz_intervals_from_box(B_hi)

        xI_all = hull3(xI_lo, xI_mid, xI_hi)
        yI_all = hull3(yI_lo, yI_mid, yI_hi)
        zI_all = hull3(zI_lo, zI_mid, zI_hi)
        dzI_all = dz_interval(xI_all, yI_all, zI_all)
        last_dz_min, last_dz_max = IA.inf(dzI_all), IA.sup(dzI_all)

        if IA.inf(zI_mid) > section
            B_hi = B_mid
            τ_hi = τ_mid
        else
            B_lo = B_mid
            τ_lo = τ_mid
        end

        if (τ_hi - τ_lo) ≤ target_time_width && last_dz_min > 0
            return (true, t_start_abs + τ_lo, t_start_abs + τ_hi, yI_lo, yI_hi, last_dz_min, last_dz_max)
        end
    end

    # Final acceptance if positive and small enough
    xI_lo, yI_lo, zI_lo = xyz_intervals_from_box(B_lo)
    xI_hi, yI_hi, zI_hi = xyz_intervals_from_box(B_hi)
    dzI_all = dz_interval(hull3(xI_lo,xI_hi,xI_lo), hull3(yI_lo,yI_hi,yI_lo), hull3(zI_lo,zI_hi,zI_lo))
    last_dz_min, last_dz_max = IA.inf(dzI_all), IA.sup(dzI_all)

    if last_dz_min > 0 && (τ_hi - τ_lo) ≤ target_time_width
        return (true, t_start_abs + τ_lo, t_start_abs + τ_hi, yI_lo, yI_hi, last_dz_min, last_dz_max)
    else
        return (false, 0.0, 0.0, IA.Interval(0,0), IA.Interval(0,0), last_dz_min, last_dz_max)
    end
end

# -------------------------------
# Initial condition set (small box)
# -------------------------------
const X0 = Hyperrectangle(
    low  = [1.0,     1.0,     20.0],
    high = [1.0001,  1.0001,  20.0001],
)

# -------------------------------
# Main (wrapped to avoid soft-scope issues)
# -------------------------------
function main()
    println("Starting CHUNKED validated integration (FAST variant)...")
    println("Initial set: $X0")
    println("Chunk length: $(CHUNK_LEN) s, total horizon: $(GLOBAL_T_MAX) s")
    println("Start time: $(now())")

    # Accumulators/state across chunks
    symbols = Char[]
    hit_brackets = Vector{Tuple{Float64,Float64}}()
    awaiting_new_cross = true
    last_below_box::Union{Nothing,Hyperrectangle} = nothing  # ← FIX: typed local
    last_below_tend_abs = 0.0

    stopped_uncertified = false
    stop_tlo_abs = 0.0
    stop_thi_abs = 0.0
    stop_segment_abs = -1

    t_offset = 0.0
    chunk_id = 0
    X_current = X0

    try
        while t_offset < GLOBAL_T_MAX && !stopped_uncertified
            chunk_id += 1
            T_chunk = min(CHUNK_LEN, GLOBAL_T_MAX - t_offset)

            # Solve this chunk
            prob_chunk = @ivp(x' = lorenz!(x), dim: 3, x(0) ∈ X_current)
            sol_tm_chunk = solve(prob_chunk, T=T_chunk, alg=GLOBAL_ALG)
            sol_chunk = overapproximate(sol_tm_chunk, Hyperrectangle)

            # Actual end time (could be < T_chunk if step cap)
            t0_rel, t1_rel = tspan_tuple(sol_chunk)
            t0_abs = t_offset + t0_rel
            t1_abs = t_offset + t1_rel

            println("— Integrated chunk $(chunk_id): t ∈ [$(round(t0_abs,digits=3)), $(round(t1_abs,digits=3))], sets: $(length(sol_chunk))")

            # Scan this chunk
            for (i, rs) in enumerate(sol_chunk)
                bnds = bounds_from_reachset(rs)
                z_low, z_high = bnds[3]
                tlo_rel, thi_rel = tspan_tuple(rs)
                tlo_abs = t_offset + tlo_rel
                thi_abs = t_offset + thi_rel

                # Update "fully below" memory & re-arm
                if z_high < SECTION
                    last_below_box = set(rs) |> box_of
                    last_below_tend_abs = thi_abs
                    if !awaiting_new_cross
                        awaiting_new_cross = true
                    end
                    continue
                end

                # Only if armed and this slab straddles the guard
                if awaiting_new_cross && (z_low <= SECTION <= z_high)
                    if last_below_box === nothing
                        continue
                    end

                    ok, t_lo_abs, t_hi_abs, yI_lo, yI_hi, dz_min, dz_max = certify_upward_crossing!(
                        lorenz!;
                        B_below=last_below_box, section=SECTION,
                        t_start_abs=last_below_tend_abs
                    )

                    if ok
                        yI_hull = IA.hull(yI_lo, yI_hi)
                        if IA.inf(yI_hull) > 0
                            push!(symbols, 'R')
                            println("   ✓ Certified ABS bracket [$(round(t_lo_abs,digits=6)), $(round(t_hi_abs,digits=6))], width=$(round(t_hi_abs-t_lo_abs,digits=6))")
                            println("     y on bracket: [$(round(IA.inf(yI_hull),digits=6)), $(round(IA.sup(yI_hull),digits=6))]  ⇒ Symbol R")
                            println("     dz/dt hull  : [$(round(dz_min,digits=6)), $(round(dz_max,digits=6))]  (>0)")
                        elseif IA.sup(yI_hull) < 0
                            push!(symbols, 'L')
                            println("   ✓ Certified ABS bracket [$(round(t_lo_abs,digits=6)), $(round(t_hi_abs,digits=6))], width=$(round(t_hi_abs-t_lo_abs,digits=6))")
                            println("     y on bracket: [$(round(IA.inf(yI_hull),digits=6)), $(round(IA.sup(yI_hull),digits=6))]  ⇒ Symbol L")
                            println("     dz/dt hull  : [$(round(dz_min,digits=6)), $(round(dz_max,digits=6))]  (>0)")
                        else
                            push!(symbols, '?')
                            println("   ✓ Certified crossing but y-sign uncertain ⇒ Symbol ?")
                            println("     ABS bracket : [$(round(t_lo_abs,digits=6)), $(round(t_hi_abs,digits=6))], width=$(round(t_hi_abs-t_lo_abs,digits=6))")
                            println("     y on bracket: [$(round(IA.inf(yI_hull),digits=6)), $(round(IA.sup(yI_hull),digits=6))]")
                            println("     dz/dt hull  : [$(round(dz_min,digits=6)), $(round(dz_max,digits=6))]  (>0)")
                        end
                        push!(hit_brackets, (t_lo_abs, t_hi_abs))
                        awaiting_new_cross = false
                    else
                        println("   ⛔ Could NOT certify this candidate. Stopping now (as requested).")
                        stopped_uncertified = true
                        stop_tlo_abs = tlo_abs
                        stop_thi_abs = thi_abs
                        stop_segment_abs = (chunk_id-1)*10^6 + i  # pseudo-global index
                        break
                    end
                end
            end

            # Early stop?
            if stopped_uncertified
                break
            end

            # Next chunk starts from terminal set of this chunk
            X_current = set(sol_chunk[end]) |> box_of
            t_offset = t1_abs
        end

        println("\n" * "="^50)
        println("RESULTS (rigorous, CHUNKED FAST)")
        println("="^50)
        println("Certified sequence: $(String(symbols))")
        println("Number of symbols: $(length(symbols))")
        if !isempty(hit_brackets)
            for (j,(a,b)) in enumerate(hit_brackets)
                println("  #$(lpad(j,2)) : ABS time bracket [$(round(a,digits=6)), $(round(b,digits=6))]  (width=$(round(b-a, digits=6)))")
            end
        end
        if stopped_uncertified
            println("\n⛔ Stopped at the FIRST uncertifiable straddling slab.")
            println("   Slab ABS time ≈ [$(round(stop_tlo_abs,digits=6)), $(round(stop_thi_abs,digits=6))]")
            println("   To push further next time, tighten GLOBAL_ALG or local TARGET_TIME_WIDTH/max_bisect.")
        else
            println("\n✅ Completed all chunks up to t = $(round(t_offset,digits=6)).")
        end

        println("\n🎉 Sequence analysis:")
        println("  L count: $(count(==('L'), symbols))")
        println("  R count: $(count(==('R'), symbols))")
        println("  ? count: $(count(==('?'), symbols))")

    catch e
        println("ERROR during chunked integration: $e")
        println("\nTroubleshooting suggestions:")
        println("1) If it fails to certify too early, shrink TARGET_TIME_WIDTH (e.g., 0.02) or raise local max_bisect.")
        println("2) If runtime is long per chunk, coarsen GLOBAL_ALG (lower orders) but expect earlier failure.")
        println("3) Reduce CHUNK_LEN to get more frequent scan/feedback at the cost of more solves.")
        rethrow(e)
    end
end

# Run
main()
