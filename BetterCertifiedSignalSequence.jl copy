############################################################
# CertifiedSignalSequence.jl  —  RIGOROUS VERSION (v5)
#
# What’s in here:
# • Certified existence via endpoint sign change + local re-integration
# • Direction: inf(dz/dt) > 0 on hull of {start, mid, end} boxes
# • Guard-local classification (uniform y-sign on bracket)
# • Hysteresis (successive hits only; no double count)
# • Absolute time brackets with a target width (default 1.25 ms)
# • Per-hit audit print: y-intervals and dz/dt interval on the bracket
############################################################

using ReachabilityAnalysis
using LazySets
using IntervalArithmetic
using Dates

const IA = IntervalArithmetic

# -------------------------------
# User knobs
# -------------------------------
const SECTION = 27.0
const TARGET_TIME_WIDTH = 0.00125    # seconds (adjust as you like)
const GLOBAL_T_MAX = 5.0

# -------------------------------
# Lorenz vector field
# -------------------------------
@taylorize function lorenz!(dx, x, p, t)
    σ, ρ, β = 10.0, 28.0, 8/3
    dx[1] = σ * (x[2] - x[1])
    dx[2] = x[1] * (ρ - x[3]) - x[2]
    dx[3] = x[1] * x[2] - β * x[3]
end

# -------------------------------
# Helpers: boxes, bounds & times
# -------------------------------
box_of(S) = S isa Hyperrectangle ? S : overapproximate(S, Hyperrectangle)

function bounds_from_reachset(rs)
    X = set(rs) |> box_of
    l = Float64.(collect(LazySets.low(X)))
    h = Float64.(collect(LazySets.high(X)))
    return [(l[1], h[1]), (l[2], h[2]), (l[3], h[3])]
end

function xyz_intervals_from_box(B::Hyperrectangle)
    l = LazySets.low(B); h = LazySets.high(B)
    xI = IA.Interval(Float64(l[1]), Float64(h[1]))
    yI = IA.Interval(Float64(l[2]), Float64(h[2]))
    zI = IA.Interval(Float64(l[3]), Float64(h[3]))
    return xI, yI, zI
end

dz_interval(xI, yI, zI) = xI*yI - (8/3)*zI
hull3(a::IA.Interval, b::IA.Interval, c::IA.Interval) = IA.hull(IA.hull(a,b), c)

# Normalize any tspan-like object to (tlo, thi) as Float64
function tspan_tuple(obj)
    ts = tspan(obj)
    if ts isa Tuple
        return (float(ts[1]), float(ts[2]))
    elseif ts isa IA.Interval
        return (float(IA.inf(ts)), float(IA.sup(ts)))
    else
        try
            return (float(first(ts)), float(last(ts)))
        catch
            error("Unsupported tspan type: $(typeof(ts))")
        end
    end
end

# -------------------------------
# Local, validated time bracketing (ABSOLUTE times)
# Returns:
#   (success, t_lo_abs, t_hi_abs, yI_lo, yI_hi, dz_min, dz_max)
# Guarantees on success:
#   sup z(t_lo_abs) < SECTION
#   inf z(t_hi_abs) > SECTION
#   inf(dz/dt) > 0 on hull of {start, mid, end} boxes
#   width ≤ target_time_width
# -------------------------------
function certify_upward_crossing!(
    lorenz!; B_below::Hyperrectangle, section::Float64,
    t_start_abs::Float64,                   # absolute time of B_below
    T_guess::Float64 = 0.02,
    T_max_local::Float64 = 0.5,
    target_time_width::Float64 = TARGET_TIME_WIDTH,
    max_expand::Int = 10,
    max_bisect::Int = 40,
    alg_refined = TMJets21a(abstol=1e-12, orderT=7, orderQ=3, maxsteps=200000)
)::Tuple{Bool,Float64,Float64,IA.Interval{Float64},IA.Interval{Float64},Float64,Float64}

    _, _, zI0 = xyz_intervals_from_box(B_below)
    if IA.sup(zI0) >= section
        return (false, 0.0, 0.0, IA.Interval(0,0), IA.Interval(0,0), 0.0, 0.0)
    end

    # 1) Expand-forward to find an end time with set strictly above section
    T = T_guess
    T_total = 0.0
    B_lo = B_below
    B_hi = B_below
    found = false

    for _ in 1:max_expand
        prob_loc = @ivp(x' = lorenz!(x), dim: 3, x(0) ∈ B_lo)
        sol_loc_tm = solve(prob_loc, T=T, alg=alg_refined)
        sol_loc = overapproximate(sol_loc_tm, Hyperrectangle)
        rs_end = sol_loc[end]
        B_end = set(rs_end) |> box_of

        _, _, zI_end = xyz_intervals_from_box(B_end)
        if IA.inf(zI_end) > section
            B_hi = B_end
            found = true
            break
        else
            B_lo = B_end
            T_total += T
            if T_total >= T_max_local
                break
            end
            T = min(T*1.5, T_max_local - T_total)
            if T <= 0
                break
            end
        end
    end
    if !found
        return (false, 0.0, 0.0, IA.Interval(0,0), IA.Interval(0,0), 0.0, 0.0)
    end

    # 2) Bisection until width ≤ target and inf(dz/dt)>0 on hull{lo,mid,hi}
    τ_lo = T_total
    τ_hi = T_total + T
    last_dz_min = -Inf
    last_dz_max =  Inf

    for _ in 1:max_bisect
        τ_mid = (τ_lo + τ_hi) / 2

        # Boxes at lo, mid, hi
        prob_mid = @ivp(x' = lorenz!(x), dim: 3, x(0) ∈ B_below)
        sol_mid_tm = solve(prob_mid, T=τ_mid, alg=alg_refined)
        sol_mid = overapproximate(sol_mid_tm, Hyperrectangle)
        B_mid = set(sol_mid[end]) |> box_of

        xI_lo, yI_lo, zI_lo = xyz_intervals_from_box(B_lo)
        xI_mid, yI_mid, zI_mid = xyz_intervals_from_box(B_mid)
        xI_hi, yI_hi, zI_hi = xyz_intervals_from_box(B_hi)

        # Direction check on hull of lo/mid/hi
        xI_all = hull3(xI_lo, xI_mid, xI_hi)
        yI_all = hull3(yI_lo, yI_mid, yI_hi)
        zI_all = hull3(zI_lo, zI_mid, zI_hi)
        dzI_all = dz_interval(xI_all, yI_all, zI_all)
        last_dz_min, last_dz_max = IA.inf(dzI_all), IA.sup(dzI_all)

        # Update bracket by sign at mid
        if IA.inf(zI_mid) > section
            B_hi = B_mid
            τ_hi = τ_mid
        else
            B_lo = B_mid
            τ_lo = τ_mid
        end

        # Stopping condition
        if (τ_hi - τ_lo) ≤ target_time_width && last_dz_min > 0
            return (true, t_start_abs + τ_lo, t_start_abs + τ_hi, yI_lo, yI_hi, last_dz_min, last_dz_max)
        end
    end

    # Final attempt after bisection budget
    xI_lo, yI_lo, zI_lo = xyz_intervals_from_box(B_lo)
    xI_hi, yI_hi, zI_hi = xyz_intervals_from_box(B_hi)
    dzI_all = dz_interval(hull3(xI_lo,xI_hi,xI_lo), hull3(yI_lo,yI_hi,yI_lo), hull3(zI_lo,zI_hi,zI_lo))
    last_dz_min, last_dz_max = IA.inf(dzI_all), IA.sup(dzI_all)
    if last_dz_min > 0 && (τ_hi - τ_lo) ≤ target_time_width
        return (true, t_start_abs + τ_lo, t_start_abs + τ_hi, yI_lo, yI_hi, last_dz_min, last_dz_max)
    else
        return (false, 0.0, 0.0, IA.Interval(0,0), IA.Interval(0,0), last_dz_min, last_dz_max)
    end
end

# -------------------------------
# Initial condition set (small box)
# -------------------------------
X0 = Hyperrectangle(
    low  = [1.0,     1.0,     20.0],
    high = [1.0001,  1.0001,  20.0001],
)

# -------------------------------
# Problem setup
# -------------------------------
prob = @ivp(x' = lorenz!(x), dim: 3, x(0) ∈ X0)

println("Starting validated integration...")
println("Initial set: $X0")

# -------------------------------
# Global algorithm parameters
# -------------------------------
alg = TMJets21a(abstol=1e-10, orderT=6, orderQ=2, maxsteps=100000)
T_max = GLOBAL_T_MAX

println("Integration time: $T_max")
println("Starting integration at $(now())...")

try
    sol_tm = solve(prob, T=T_max, alg=alg)
    println("Integration completed successfully!")
    println("Number of reach sets: $(length(sol_tm))")
    println("Time span covered: $(tspan(sol_tm))")

    if length(sol_tm) == 0
        println("❌ Empty solution.")
        exit()
    end

    # Overapprox to Hyperrectangles for robust bounds in main scan
    sol = overapproximate(sol_tm, Hyperrectangle)

    # Quick trajectory check
    println("\nQuick trajectory check:")
    sample_indices = [1, max(1, div(length(sol),4)), max(1, div(length(sol),2)),
                      max(1, 3*div(length(sol),4)), length(sol)]
    sample_indices = unique(filter(i -> 1 <= i <= length(sol), sample_indices))

    z_samples = Tuple{Float64,Float64}[]
    for i in sample_indices
        rs = sol[i]
        bnds = bounds_from_reachset(rs)
        z_low, z_high = bnds[3]
        push!(z_samples, (z_low, z_high))
        t_lo_seg, t_hi_seg = tspan_tuple(rs)
        t_mid = (t_lo_seg + t_hi_seg)/2
        println("  t≈$(round(t_mid, digits=3)): z ∈ [$(round(z_low, digits=3)), $(round(z_high, digits=3))]")
    end
    z_min_seen = minimum(first, z_samples)
    z_max_seen = maximum(last,  z_samples)
    println("\nOverall z range sampled: [$(round(z_min_seen, digits=3)), $(round(z_max_seen, digits=3))]")

    # --------------------------------
    # Certified scan with hysteresis + local bracketing
    # --------------------------------
    symbols = Char[]
    hit_brackets = Vector{Tuple{Float64,Float64}}()
    max_symbols = 10

    awaiting_new_cross = true
    crossings_checked = 0

    println("\nCertified crossing search (with local bracketing)...")
    for i in 1:length(sol)
        rs = sol[i]
        bnds = bounds_from_reachset(rs)
        x_low, x_high = bnds[1]
        y_low, y_high = bnds[2]
        z_low, z_high = bnds[3]

        crossings_checked += 1
        if i % 500 == 0
            println("... checked segment $i/$(length(sol)), certified symbols: $(length(symbols))")
        end

        if awaiting_new_cross
            # Arm only while entirely below
            if z_high < SECTION
                continue
            else
                # Try to certify only if slab straddles the guard
                if z_low <= SECTION <= z_high
                    # Find a prior slab fully below for B_below and its absolute end time
                    i_below = i - 1
                    B_below = nothing
                    t_start_abs = nothing
                    while i_below >= 1
                        rs_prev = sol[i_below]
                        b_prev = bounds_from_reachset(rs_prev)
                        if b_prev[3][2] < SECTION
                            B_below = set(rs_prev) |> box_of
                            _, t_end_prev = tspan_tuple(rs_prev)
                            t_start_abs = t_end_prev
                            break
                        end
                        i_below -= 1
                    end
                    if B_below === nothing || t_start_abs === nothing
                        continue
                    end

                    t_lo_seg, t_hi_seg = tspan_tuple(rs)
                    println("Potential upward crossing near segment $i, t≈[$(round(t_lo_seg,digits=3)),$(round(t_hi_seg,digits=3))]: z ∈ [$(round(z_low,digits=3)), $(round(z_high,digits=3))]")

                    ok, t_lo_abs, t_hi_abs, yI_lo, yI_hi, dz_min, dz_max = certify_upward_crossing!(
                        lorenz!;
                        B_below=B_below, section=SECTION,
                        t_start_abs = t_start_abs,
                        T_guess=0.02, T_max_local=0.5,
                        target_time_width=TARGET_TIME_WIDTH,
                        max_expand=10, max_bisect=40,
                        alg_refined=TMJets21a(abstol=1e-12, orderT=7, orderQ=3, maxsteps=200000)
                    )

                    if ok
                        # Uniform y-sign on bracket (use hull of endpoints)
                        yI_hull = IA.hull(yI_lo, yI_hi)
                        if IA.inf(yI_hull) > 0
                            push!(symbols, 'R')
                            println("  ✓ Certified upward crossing with ABS time bracket [$(round(t_lo_abs,digits=6)), $(round(t_hi_abs,digits=6))], width=$(round(t_hi_abs - t_lo_abs, digits=6))")
                            println("    y on bracket: [$(round(IA.inf(yI_hull),digits=6)), $(round(IA.sup(yI_hull),digits=6))]  ⇒ Symbol R")
                            println("    dz/dt hull  : [$(round(dz_min,digits=6)), $(round(dz_max,digits=6))]  (>0 certified)")
                        elseif IA.sup(yI_hull) < 0
                            push!(symbols, 'L')
                            println("  ✓ Certified upward crossing with ABS time bracket [$(round(t_lo_abs,digits=6)), $(round(t_hi_abs,digits=6))], width=$(round(t_hi_abs - t_lo_abs, digits=6))")
                            println("    y on bracket: [$(round(IA.inf(yI_hull),digits=6)), $(round(IA.sup(yI_hull),digits=6))]  ⇒ Symbol L")
                            println("    dz/dt hull  : [$(round(dz_min,digits=6)), $(round(dz_max,digits=6))]  (>0 certified)")
                        else
                            push!(symbols, '?')
                            println("  ✓ Certified upward crossing but y-sign uncertain on bracket ⇒ Symbol ?")
                            println("    ABS bracket : [$(round(t_lo_abs,digits=6)), $(round(t_hi_abs,digits=6))], width=$(round(t_hi_abs - t_lo_abs, digits=6))")
                            println("    y on bracket: [$(round(IA.inf(yI_hull),digits=6)), $(round(IA.sup(yI_hull),digits=6))]")
                            println("    dz/dt hull  : [$(round(dz_min,digits=6)), $(round(dz_max,digits=6))]  (>0 certified)")
                        end
                        push!(hit_brackets, (t_lo_abs, t_hi_abs))
                        awaiting_new_cross = false
                        if length(symbols) >= max_symbols
                            println("Reached $max_symbols certified symbols, stopping scan.")
                            break
                        end
                    else
                        println("  ✗ Could not certify an upward crossing after local bracketing (try tighter params).")
                    end
                end
            end
        else
            # Re-arm when fully below again (successive hits only)
            if z_high < SECTION
                awaiting_new_cross = true
            end
            continue
        end
    end

    println("\nCrossings checked: $crossings_checked")

    println("\n" * "="^50)
    println("RESULTS (rigorous)")
    println("="^50)
    println("Certified sequence: $(String(symbols))")
    println("Number of symbols: $(length(symbols))")
    if !isempty(hit_brackets)
        for (j,(a,b)) in enumerate(hit_brackets)
            println("  #$(lpad(j,2)) : ABS time bracket [$(round(a,digits=6)), $(round(b,digits=6))]  (width=$(round(b-a, digits=6)))")
        end
    end

    if isempty(symbols)
        println("\nNo crossings certified. Consider:")
        println("- Increase local search horizon (T_max_local) or bisection depth")
        println("- Tighten global/local tolerances (abstol, orderT/orderQ)")
        println("- Shrink initial set X0 to reduce wrapping")
        println("- Extend total time T_max")
    else
        println("\n🎉 SUCCESS! Sequence analysis:")
        println("L count: $(count(==('L'), symbols))")
        println("R count: $(count(==('R'), symbols))")
        println("? count: $(count(==('?'), symbols))")
    end

catch e
    println("ERROR during integration: $e")
    println("\nTroubleshooting suggestions:")
    println("1. Ensure ReachabilityAnalysis/LazySets/IntervalArithmetic versions are compatible")
    println("2. Try tighter tolerances or higher orders (abstol, orderT, orderQ)")
    println("3. Try a smaller initial set X0")
    rethrow(e)
end
